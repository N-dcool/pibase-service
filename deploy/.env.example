# — PiBase MVP – Environment Variables —————————————
# Copy this file to .env and fill in the values.

# DockerHub username (used to pull the image)
DOCKERHUB_USERNAME=your-dockerhub-username

# JWT signing secret – MUST be at least 256 bits (32+ characters)
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_generate_with_command_above

# Public hostname the Pi is reachable at (via Cloudflare tunnel)
PUBLIC_HOST=db.nareshchoudhary.com

# Backend hostname used by Cloudflare Worker (internal, tunnel-routed)
BACKEND_HOST=backend.nareshchoudhary.com

# CORS – comma-separated origins allowed to call the API
# The Cloudflare Worker proxies from db.nareshchoudhary.com, so that's the origin
ALLOWED_ORIGINS=https://db.nareshchoudhary.com

# Spring profile – do not change for production
SPRING_PROFILES_ACTIVE=prod